{
  "name": "@ivorycom/observability",
  "version": "0.2.0",
  "description": "Ivorycom shared OpenTelemetry instrumentation for Node/Fastify. Runtime deps are declared HERE (not in ts/) so they hoist into consumers that git-install this package.",
  "main": "ts/dist/index.js",
  "types": "ts/dist/index.d.ts",
  "files": [
    "register.mjs",
    "ts/dist",
    "ts/src",
    "ts/tsconfig.json"
  ],
  "scripts": {
    "build": "tsc -p ts/tsconfig.json",
    "test": "vitest run",
    "prepare": "test -f ts/dist/index.js || tsc -p ts/tsconfig.json"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.219.0",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "fastify-plugin": "^5.0.1",
    "pino": "^9.6.0"
  },
  "peerDependencies": {
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "fastify": "^5.2.0",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  },
  "license": "UNLICENSED",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/ivorycom-platform/ivorycom-observability.git",
    "directory": "ts"
  },
  "exports": {
    ".": {
      "types": "./ts/dist/index.d.ts",
      "default": "./ts/dist/index.js"
    },
    "./register": "./register.mjs"
  }
}